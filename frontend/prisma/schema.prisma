// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ShopStatus {
  WANT
  VISITED
  FAVORITE
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String?          // OAuthユーザーはパスワードなし
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  profile          Profile?
  userShops        UserShop[]
  shopPhotos       ShopPhoto[]
  accounts         Account[]
  plan             UserPlan         @default(FREE)
  premiumExpiresAt DateTime?
  placesUsageLogs  PlacesUsageLog[]
  dailyUsageLogs   DailyUsageLog[]
}

// OAuthプロバイダーとの紐付けテーブル
model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String   // 'google' | 'line' | 'apple'
  providerAccountId String   // プロバイダー側のユーザーID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shop {
  id        String       @id @default(uuid())
  name      String
  address   String?
  lat       Float?
  lng       Float?
  placeId   String?
  source    String       @default("google")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  userShops  UserShop[]
  shopPhotos ShopPhoto[]
  shopTags   ShopTag[]

  @@index([placeId])
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shopTags  ShopTag[]
}

model ShopTag {
  id        String   @id @default(uuid())
  shopId    String
  tagId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([shopId, tagId])
}

model UserShop {
  id        String      @id @default(uuid())
  userId    String
  shopId    String
  status    ShopStatus
  memo      String?
  rating    Int?
  visitedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
}

model ShopPhoto {
  id        String   @id @default(uuid())
  shopId    String
  userId    String
  imageUrl  String
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// フリーミアムプランの区分
enum UserPlan {
  FREE
  PREMIUM
}

// Google検索登録の月次利用状況を管理するログ
model PlacesUsageLog {
  id         String   @id @default(uuid())
  userId     String
  monthKey   String   // "YYYYMM" e.g. "202603"
  usedCount  Int      @default(0)
  videoCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
  @@index([userId, monthKey])
}

// 1日あたりのAPI呼び出し回数・お店登録回数を管理するログ
model DailyUsageLog {
  id           String   @id @default(uuid())
  userId       String
  dayKey       String   // "YYYYMMDD" e.g. "20260315"
  apiCallCount Int      @default(0)
  shopRegCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}
